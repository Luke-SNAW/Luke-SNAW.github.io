{"pageProps":{"note":{"id":"HtVLXiN97I2jTm8h2NEVQ","title":"Functional Programming","desc":"","updated":1676866195141,"created":1644825118480,"custom":{},"fname":"dev.functional-programming","type":"note","vault":{"fsPath":"vault"},"contentHash":"9316c53fa348e2a97dc192efd7fc9270","links":[{"type":"wiki","from":{"fname":"dev.functional-programming","id":"HtVLXiN97I2jTm8h2NEVQ","vaultName":"vault"},"value":"tags.bookshelf","alias":"#bookshelf","position":{"start":{"line":10,"column":136,"offset":660},"end":{"line":10,"column":146,"offset":670},"indent":[]},"xvault":false,"to":{"fname":"tags.bookshelf"}},{"type":"wiki","from":{"fname":"dev.functional-programming","id":"HtVLXiN97I2jTm8h2NEVQ","vaultName":"vault"},"value":"tags.bookshelf","alias":"#bookshelf","position":{"start":{"line":11,"column":174,"offset":844},"end":{"line":11,"column":184,"offset":854},"indent":[]},"xvault":false,"to":{"fname":"tags.bookshelf"}}],"anchors":{"collections":{"type":"header","text":"Collections","value":"collections","line":8,"column":0,"depth":2},"books":{"type":"header","text":"Books","value":"books","line":14,"column":0,"depth":2}},"children":["4vjiywn2gjb1gzms9bqustx","gzly3lvlt6sxs55qpnqtb8y","ew2g878jseu0jd1334f4z25","1x5p06d62ckb8nrirqr94ag","a4h1127hob3u80faagbqbf9","z51ij8wnfiblts8ls4h92yo","pj7kmrdb0dqqvzbu0tljcg6","cdgkaoy6064zew14hry05b3","0bqed1lx0c7hfr0txl97vrz","m3zpjkkh97bf1ao5rgm3k8l"],"parent":"ZbdkdApFqLdks4Moq92R9","data":{}},"body":"<h1 id=\"functional-programming\">Functional Programming<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#functional-programming\"></a></h1>\n<h2 id=\"collections\">Collections<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#collections\"></a></h2>\n<ul>\n<li><a href=\"https://www.syncfusion.com/blogs/post/pure-and-impure-functions-in-javascript-a-complete-guide.aspx\">Pure and Impure Functions in JavaScript: A Complete Guide</a></li>\n<li><a href=\"https://divyanshu013.dev/blog/functional-programming-constructs/\">Functional programming constructs</a></li>\n<li><a href=\"https://medium.com/@rivoltafilippo/function-composition-in-large-react-applications-best-practices-and-real-world-examples-805aba8d37b1\">Function Composition in Large React Applications: Best Practices and Real-World Examples</a></li>\n</ul>\n<h2 id=\"books\">Books<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#books\"></a></h2>\n<ul>\n<li><a href=\"https://github.com/getify/Functional-Light-JS\">Functional-Light JavaScript</a> is a book balanced, pragmatic look at FP in JavaScript. <a class=\"color-tag\" style=\"--tag-color: #c77986;\" href=\"/notes/0ce4gh9w22elz738jbxchfo\">#bookshelf</a></li>\n<li><a href=\"https://github.com/MostlyAdequate/mostly-adequate-guide\">Professor Frisby's Mostly Adequate Guide to Functional Programming</a>: Mostly adequate guide to FP (in javascript) <a class=\"color-tag\" style=\"--tag-color: #c77986;\" href=\"/notes/0ce4gh9w22elz738jbxchfo\">#bookshelf</a>\n<ul>\n<li><a href=\"https://mostly-adequate.gitbook.io/mostly-adequate-guide/\">https://mostly-adequate.gitbook.io/mostly-adequate-guide/</a></li>\n</ul>\n</li>\n</ul>\n<hr>\n<blockquote>\n<p>Functional programming deals with values; imperative programming deals with objects.<br>\n-Alexander Stepanov, “Elements of Programming”, p. 5</p>\n</blockquote>\n<hr>\n<strong>Children</strong>\n<ol>\n<li><a href=\"/notes/cdgkaoy6064zew14hry05b3\">A primer on functional architecture</a></li>\n<li><a href=\"/notes/1x5p06d62ckb8nrirqr94ag\">Composing Software</a></li>\n<li><a href=\"/notes/4vjiywn2gjb1gzms9bqustx\">Curry or Partial Application?</a></li>\n<li><a href=\"/notes/a4h1127hob3u80faagbqbf9\">FP + Monads</a></li>\n<li><a href=\"/notes/z51ij8wnfiblts8ls4h92yo\">Functional Programming - How and Why</a></li>\n<li><a href=\"/notes/pj7kmrdb0dqqvzbu0tljcg6\">Functional Programming: Part 5 - Functors</a></li>\n<li><a href=\"/notes/gzly3lvlt6sxs55qpnqtb8y\">Functional composition</a></li>\n<li><a href=\"/notes/ew2g878jseu0jd1334f4z25\">The Power of Currying</a></li>\n<li><a href=\"/notes/0bqed1lx0c7hfr0txl97vrz\">Why Functional Programming Should Be the Future of Software Development</a></li>\n<li><a href=\"/notes/m3zpjkkh97bf1ao5rgm3k8l\">Why I Am Learning Category Theory 1</a></li>\n</ol>","noteIndex":{"id":"Iy0MoL0KnL55Br3AfTS2C","title":"Luke","desc":"","updated":1719298470122,"created":1644449449778,"custom":{"nav_order":0,"permalink":"/"},"fname":"root","type":"note","vault":{"fsPath":"vault"},"contentHash":"e2eeab1e028fef2e31ef069a6df05209","links":[{"type":"wiki","from":{"fname":"root","id":"Iy0MoL0KnL55Br3AfTS2C","vaultName":"vault"},"value":"life-tips","position":{"start":{"line":13,"column":5,"offset":267},"end":{"line":13,"column":29,"offset":291},"indent":[]},"xvault":false,"sameFile":false,"to":{"fname":"life-tips","anchorHeader":"wodenokoto"}},{"type":"wiki","from":{"fname":"root","id":"Iy0MoL0KnL55Br3AfTS2C","vaultName":"vault"},"value":"journal.what-i-read-in","alias":"What I read in 2024","position":{"start":{"line":38,"column":3,"offset":1560},"end":{"line":38,"column":49,"offset":1606},"indent":[]},"xvault":false,"sameFile":false,"to":{"fname":"journal.what-i-read-in"}},{"type":"wiki","from":{"fname":"root","id":"Iy0MoL0KnL55Br3AfTS2C","vaultName":"vault"},"value":"journal.what-i-read-in.2023","alias":"2023","position":{"start":{"line":39,"column":5,"offset":1611},"end":{"line":39,"column":41,"offset":1647},"indent":[]},"xvault":false,"sameFile":false,"to":{"fname":"journal.what-i-read-in.2023"}},{"type":"wiki","from":{"fname":"root","id":"Iy0MoL0KnL55Br3AfTS2C","vaultName":"vault"},"value":"journal.what-i-read-in.2022","alias":"2022","position":{"start":{"line":40,"column":5,"offset":1652},"end":{"line":40,"column":41,"offset":1688},"indent":[]},"xvault":false,"sameFile":false,"to":{"fname":"journal.what-i-read-in.2022"}},{"type":"wiki","from":{"fname":"root","id":"Iy0MoL0KnL55Br3AfTS2C","vaultName":"vault"},"value":"journal.what-i-struggled-